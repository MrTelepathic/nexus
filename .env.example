# ============================================================
# Nexus Platform — Environment Configuration
# Copy to .env and fill in values. NEVER commit .env.
# ============================================================

# --- Application ---
APP_ENV=development
APP_DEBUG=true
APP_SECRET_KEY=change-me-to-random-64-chars
APP_LOG_LEVEL=INFO

# --- Telegram ---
BOT_TOKEN=1234567890:ABCdefGHIjklMNOpqrsTUVwxyz
BOT_WEBHOOK_SECRET_TOKEN=random-secret-for-webhook
BOT_WEBHOOK_URL=https://your-domain.com/bot/webhook
MINI_APP_URL=https://your-domain.com/miniapp

# --- Database (PostgreSQL) ---
DATABASE_URL=postgresql+asyncpg://nexus:nexus_dev@localhost:5432/nexus
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# --- Redis ---
REDIS_URL=redis://localhost:6379/0
REDIS_CACHE_TTL=300

# --- RabbitMQ ---
RABBITMQ_URL=amqp://nexus:nexus_dev@localhost:5672/

# --- MinIO / S3 ---
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=nexus-files
MINIO_SECURE=false

# --- AI / LLM ---
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_BUDGET_MODEL=gpt-4o-mini
LOCAL_LLM_URL=http://localhost:11434/api

# --- Qdrant (optional, for advanced RAG) ---
QDRANT_URL=http://localhost:6333

# --- TON Blockchain ---
TON_API_KEY=...
TON_NETWORK=testnet
TON_ESCROW_ADDRESS=

# --- Sentry ---
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1

# --- Payment ---
STARS_PROVIDER_TOKEN=
FIAT_PAYMENT_API_KEY=
FIAT_PAYMENT_API_SECRET=
